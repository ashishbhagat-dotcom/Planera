# =============================================================================
# Planera — Environment Variables
# Copy this file to .env and fill in values before running docker compose.
# =============================================================================

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------

# Secret key — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Settings module to load (use development for local, production for prod)
DJANGO_SETTINGS_MODULE=config.settings.development

# Comma-separated list of hostnames Django will serve (production only)
# Example: ALLOWED_HOSTS=planera.example.com,www.planera.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

POSTGRES_DB=planera
POSTGRES_USER=planera
POSTGRES_PASSWORD=planera
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

# Used for Django Channels (WebSocket), Celery broker, and Celery result backend
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# CORS (production only — comma-separated origins)
# ---------------------------------------------------------------------------

# Example: CORS_ALLOWED_ORIGINS=https://planera.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Frontend (Vite dev server)
# ---------------------------------------------------------------------------

# URL the Vite dev-server proxies /api and /ws requests to
VITE_PROXY_TARGET=http://api:8000
VITE_WS_PROXY_TARGET=ws://api:8000
